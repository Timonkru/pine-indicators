//@version=6
// FUTURE-VOLUMEN-PROFIL AUF CFD  (v2 — Auto-Symbol + Session/Woche/Monat)
// Zieht echtes Volumen vom passenden Future (AUTO erkannt am Chart-Symbol), verteilt
// es auf die PREIS-Zonen des CFD-Charts -> horizontales Profil in CFD-Koordinaten
// (Basis-Offset automatisch gelöst: Preis=CFD, Gewicht=Future-Vol).
// Anker: Session(Tag)/Woche/Monat — Profil setzt sich pro Periode zurück.
// Inkrementelle Map-Akkumulation (kein Lookback-Loop -> auch Monat ok).
// Ausgabe: Histogramm rechts + POC (rot) + VAH/VAL (blau). Dick=HVN, dünn=LVN.
indicator("Future-Volumen-Profil (CFD) v2", overlay = true,
     max_boxes_count = 250, max_lines_count = 15, max_labels_count = 12)

anchorIn = input.string("Session (Tag)", "Anker",
     options = ["Session (Tag)", "Woche", "Monat"], group = "Profil")
vaPct    = input.float(70, "Value-Area %", minval = 50, maxval = 90, step = 5, group = "Profil")
binPts   = input.float(0.0, "Zonen-Breite (Punkte, 0=auto)", minval = 0, group = "Profil",
     tooltip = "0 = automatisch aus ATR. Sonst feste Punkt-Breite je Zone.")
profW    = input.int(30, "Profil-Breite (Bars)", minval = 5, group = "Darstellung")
gap      = input.int(2,  "Abstand vom Preis (Bars)", minval = 0, group = "Darstellung")
posMode  = input.string("Session-Start", "Profil-Position",
     options = ["Session-Start", "Rechts (am Preis)"], group = "Darstellung",
     tooltip = "Session-Start: Profil sitzt am Perioden-Anfang (klassisch, wächst live mit). Rechts: schwebt am aktuellen Preis.")
showHist = input.bool(true, "Histogramm zeigen", group = "Darstellung")
pocCol   = input.color(color.red, "POC", group = "Darstellung")
vaCol    = input.color(color.blue, "Value Area", group = "Darstellung")
barCol   = input.color(color.teal, "Volumen-Balken", group = "Darstellung")

autoFut   = input.bool(true, "Future-Symbol AUTO erkennen", group = "Volumen")
futManual = input.symbol("EUREX:FDAX1!", "…sonst manuell", group = "Volumen")
useChart  = input.bool(false, "Chart-Volumen nutzen (auf nativem Future-Chart)", group = "Volumen")

// ---- Auto-Erkennung: Chart-Symbol -> passender Future ----
f_detectFut() =>
    s = str.lower(syminfo.ticker) + " " + str.lower(syminfo.prefix) + " " + str.lower(syminfo.description)
    isNQ  = str.contains(s, "nas") or str.contains(s, "ndx") or str.contains(s, "us100") or str.contains(s, "ustec") or str.contains(s, "tech100") or str.contains(s, "nq1") or str.contains(s, "nq!")
    isYM  = str.contains(s, "dow") or str.contains(s, "us30") or str.contains(s, "dji") or str.contains(s, "ym1") or str.contains(s, "ym!") or str.contains(s, "wall street")
    isDAX = str.contains(s, "dax") or str.contains(s, "ger40") or str.contains(s, "de40") or str.contains(s, "german")
    isFTSE = str.contains(s, "ftse") or str.contains(s, "uk100") or str.contains(s, "ukx")
    isES  = str.contains(s, "us500") or str.contains(s, "sp500") or str.contains(s, "spx") or str.contains(s, "s&p") or str.contains(s, "es1") or str.contains(s, "es!")
    isDAX ? "EUREX:FDAX1!" : isFTSE ? "ICEEUR:Z1!" : isNQ ? "CME_MINI:NQ1!" :
     isYM ? "CBOT_MINI:YM1!" : isES ? "CME_MINI:ES1!" : syminfo.tickerid

futSym = autoFut ? f_detectFut() : futManual
futVol = request.security(futSym, timeframe.period, volume, ignore_invalid_symbol = true)
useFut = not useChart
volBar = useFut ? (na(futVol) ? volume : futVol) : volume

// ---- Anker ----
res  = anchorIn == "Woche" ? "W" : anchorIn == "Monat" ? "M" : "D"
newP = timeframe.change(res)

var map<int, float> vmap = map.new<int, float>()
var float binW = na
var float sHi  = na
var float sLo  = na
var int   startBar = 0   // Bar-Index, an dem die aktuelle Periode begann

atr14 = ta.atr(14)   // global (Pine-State) — nicht im if-Block

if newP or barstate.isfirst
    map.clear(vmap)
    binW := binPts > 0 ? binPts : math.max(syminfo.mintick, nz(atr14) * 0.5)
    sHi  := high
    sLo  := low
    startBar := bar_index

// ---- Akkumulieren (JEDER Bar) ----
if not na(binW) and binW > 0 and not na(volBar) and volBar > 0 and not na(high)
    loK = int(math.floor(low / binW))
    hiK = int(math.floor(high / binW))
    n   = math.max(1, hiK - loK + 1)
    share = volBar / n
    for k = loK to hiK
        prev = map.get(vmap, k)
        map.put(vmap, k, (na(prev) ? 0.0 : prev) + share)
    sHi := math.max(nz(sHi, high), high)
    sLo := math.min(nz(sLo, low), low)

// ---- Zeichnen (nur letzter Bar) ----
var box[]   boxes = array.new_box()
var line[]  lines = array.new_line()
var label[] labs  = array.new_label()

f_clear() =>
    for b in boxes
        box.delete(b)
    array.clear(boxes)
    for l in lines
        line.delete(l)
    array.clear(lines)
    for lb in labs
        label.delete(lb)
    array.clear(labs)

if barstate.islast and map.size(vmap) > 1
    f_clear()
    keys = map.keys(vmap)
    array.sort(keys, order.ascending)
    nK = array.size(keys)
    vols = array.new_float(nK, 0.0)
    total = 0.0
    maxv = 0.0
    pocI = 0
    for j = 0 to nK - 1
        v = map.get(vmap, array.get(keys, j))
        vv = na(v) ? 0.0 : v
        array.set(vols, j, vv)
        total += vv
        if vv > maxv
            maxv := vv
            pocI := j
    // Value Area um POC (über sortierte Zonen)
    vaVol = array.get(vols, pocI)
    loI = pocI
    hiI = pocI
    target = total * vaPct / 100.0
    while vaVol < target and (loI > 0 or hiI < nK - 1)
        upV = hiI < nK - 1 ? array.get(vols, hiI + 1) : -1.0
        dnV = loI > 0 ? array.get(vols, loI - 1) : -1.0
        if upV >= dnV
            hiI += 1
            vaVol += math.max(upV, 0.0)
        else
            loI -= 1
            vaVol += math.max(dnV, 0.0)
    pocPrice = (array.get(keys, pocI) + 0.5) * binW
    vah = (array.get(keys, hiI) + 1) * binW
    val = array.get(keys, loI) * binW
    // Position: Session-Start (Profil sitzt am Perioden-Anfang) oder Rechts (am Preis)
    posSession = posMode == "Session-Start"
    baseX  = posSession ? startBar : bar_index + gap        // linke Kante des Histogramms
    rightX = posSession ? bar_index : baseX + profW         // rechtes Ende der POC/VA-Linien + Labels
    // Histogramm (wächst nach rechts ab baseX)
    if showHist
        for j = 0 to nK - 1
            v = array.get(vols, j)
            w = maxv > 0 ? int(math.round(profW * v / maxv)) : 0   // v6: float->int explizit
            if w > 0
                k = array.get(keys, j)
                y1 = k * binW
                y2 = y1 + binW
                inVa = j >= loI and j <= hiI
                bx = box.new(baseX, y2, baseX + w, y1, border_color = na,
                     bgcolor = color.new(barCol, inVa ? 45 : 72))
                array.push(boxes, bx)
    // POC + VA-Linien spannen die Periode: Start -> jetzt
    array.push(lines, line.new(startBar, pocPrice, rightX, pocPrice, color = pocCol, width = 2))
    array.push(lines, line.new(startBar, vah, rightX, vah, color = vaCol, style = line.style_dashed))
    array.push(lines, line.new(startBar, val, rightX, val, color = vaCol, style = line.style_dashed))
    array.push(labs, label.new(rightX, pocPrice, "POC " + str.tostring(pocPrice, format.mintick),
         style = label.style_label_left, color = color.new(pocCol, 20), textcolor = color.white, size = size.small))
    array.push(labs, label.new(rightX, vah, "VAH " + str.tostring(vah, format.mintick),
         style = label.style_label_left, color = color.new(vaCol, 30), textcolor = color.white, size = size.small))
    array.push(labs, label.new(rightX, val, "VAL " + str.tostring(val, format.mintick),
         style = label.style_label_left, color = color.new(vaCol, 30), textcolor = color.white, size = size.small))
    // Quelle bestaetigen — am Perioden-Anfang oben
    src = useChart ? "Chart-Vol" : (na(futVol) ? "⚠ " + futSym + " KEINE DATEN" : "Future " + futSym)
    array.push(labs, label.new(startBar, sHi, src + " · " + anchorIn,
         style = label.style_label_down, color = color.new(color.black, 25), textcolor = color.white, size = size.small))
