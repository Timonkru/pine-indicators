//@version=6
indicator('Session Candle Levels & Alerts — Intraday', shorttitle = 'Session Levels ID', overlay = true, max_lines_count = 30, max_boxes_count = 15, max_labels_count = 60)

// ============================================================
//  🎛️ DISPLAY MASTER
// ============================================================
showLabels    = input.bool(true,  '🏷️ Show all labels (master)', group = '🎛️ Display', tooltip = 'Global switch: disables all label annotations on the chart (volume %, retests, outlier warnings, event signals etc.). Lines/boxes/alerts stay active.')

// helper: labels are only created when the master switch is on
lbl(x, y, txt, color, textcolor, style, size) =>
    showLabels ? label.new(x = x, y = y, text = txt, color = color, textcolor = textcolor, style = style, size = size) : na

// === EINSTELLUNGEN 15-MIN ===
showEU       = input.bool(true,  'EU markets active',           group = '📊 15-Min Candles (EU/US)')
showUS       = input.bool(true,  'US markets & gold active',    group = '📊 15-Min Candles (EU/US)')
showEU_2nd15 = input.bool(true,  'EU 2nd candle (15m)',        group = '📊 15-Min Candles (EU/US)')
showEU_7th15 = input.bool(true,  'EU 7th candle (15m)',        group = '📊 15-Min Candles (EU/US)')
showUS_2nd15 = input.bool(true,  'US 2nd candle (15m)',        group = '📊 15-Min Candles (EU/US)')
showUS_7th15 = input.bool(true,  'US 7th candle (15m)',        group = '📊 15-Min Candles (EU/US)')
euColor      = input.color(color.blue,   'EU color',          group = '📊 15-Min Candles (EU/US)')
usColor      = input.color(color.orange, 'US/gold color',     group = '📊 15-Min Candles (EU/US)')
lineWidth    = input.int(2, 'Line width', minval = 1, maxval = 5, group = '📊 15-Min Candles (EU/US)')

// === EINSTELLUNGEN HK50 ===
showHK50     = input.bool(true,  'HK50 active',                group = '🌏 HK50 Special')
showHK_230   = input.bool(true,  'HK50 02:30 Candle (15m)',   group = '🌏 HK50 Special')
hkColor      = input.color(color.purple, 'HK50 color',        group = '🌏 HK50 Special')

// === EINSTELLUNGEN JPN225 ===
showJPN      = input.bool(true,  'JPN225 active',              group = '🗾 JPN225 Special')
showJPN_050  = input.bool(true,  'JPN225 00:50 Candle (10m)', group = '🗾 JPN225 Special')
jpnColor     = input.color(color.teal,   'JPN225 color',      group = '🗾 JPN225 Special')

// === EINSTELLUNGEN GOLD SESSION CANDLES ===
showGoldSession = input.bool(true, 'Gold session candles active', group = '🥇 Gold/Commodities Sessions')
showGold_0145   = input.bool(true, 'Gold 01:45 (after NY-Asia)', group = '🥇 Gold/Commodities Sessions', tooltip = 'Quiet phase after NY-Asia handover, Shanghai wakes up')
showGold_1415   = input.bool(true, 'Gold 14:15 (after EU lunch)', group = '🥇 Gold/Commodities Sessions', tooltip = 'After the EU lunch lull, before the US open')
goldSessionColor = input.color(color.orange, 'Gold session color', group = '🥇 Gold/Commodities Sessions')

// === EINSTELLUNGEN FOREX SESSION CANDLES ===
showForexSession = input.bool(true, 'Forex session candles active', group = '💱 Forex Sessions')
showFX_0815      = input.bool(true, 'FX 08:15 (after pre-London)', group = '💱 Forex Sessions', tooltip = 'Quiet phase after Asia/pre-London, London interbank session starts')
forexSessionColor = input.color(color.purple, 'Forex session color', group = '💱 Forex Sessions')

// === EINSTELLUNGEN 5-MIN ===
show5MinEU   = input.bool(true,  'EU 5-Min Levels',           group = '📈 5-Min Candles (1. & 4.)')
show5MinUS   = input.bool(true,  'US 5-Min Levels',           group = '📈 5-Min Candles (1. & 4.)')
showEU1stLow = input.bool(true,  'Show EU 1st candle low',    group = '📈 5-Min Candles (1. & 4.)')
showUS1stLow = input.bool(true,  'Show US 1st candle low',    group = '📈 5-Min Candles (1. & 4.)')
eu5MinColor  = input.color(color.green, 'EU 5-min color',     group = '📈 5-Min Candles (1. & 4.)')
us5MinColor  = input.color(color.red,   'US 5-min color',     group = '📈 5-Min Candles (1. & 4.)')

// === 8 BALL & TEENAGER (Tom Hougaard) ===
show8Ball    = input.bool(true,  '8 Ball & Teenager active (Tom Hougaard)',  group = '🎱 8 Ball & Teenager (Hougaard)', tooltip = 'Marks the 8th (8 Ball) and 13th (Teenager) 5-min candle after the open. Original strategy: FTSE/indices.')
show8BallEU  = input.bool(true,  'EU 8 Ball  (5-Min Bar 8 → 09:35-09:40)', group = '🎱 8 Ball & Teenager (Hougaard)')
showTeenEU   = input.bool(true,  'EU Teenager (5-Min Bar 13 → 10:00-10:05)', group = '🎱 8 Ball & Teenager (Hougaard)')
show8BallUS  = input.bool(true,  'US 8 Ball  (5-Min Bar 8 → 16:05-16:10)', group = '🎱 8 Ball & Teenager (Hougaard)')
showTeenUS   = input.bool(true,  'US Teenager (5-Min Bar 13 → 16:30-16:35)', group = '🎱 8 Ball & Teenager (Hougaard)')
orderlyMult  = input.float(1.5, 'Orderly filter (max. range vs. avg)', minval = 1.0, maxval = 5.0, step = 0.1, group = '🎱 8 Ball & Teenager (Hougaard)', tooltip = 'Tom Hougaard rule: only trade the bar if its range is at most this factor times the average of the preceding bars. Outlier bars are skipped.')
ballColor    = input.color(color.fuchsia, '8 Ball color',  group = '🎱 8 Ball & Teenager (Hougaard)')
teenColor    = input.color(color.aqua,    'Teenager color', group = '🎱 8 Ball & Teenager (Hougaard)')

// === NEU: PRE-MARKET LEVELS ===
showPreMarket30 = input.bool(true, 'Show 30-min low before cash open', group = '🌅 Pre-Market Levels')
showPreMarket10 = input.bool(true, 'Show 10-min high/low before cash open', group = '🌅 Pre-Market Levels')
showPreMarketLabels = input.bool(true, 'Show pre-market labels', group = '🌅 Pre-Market Levels', tooltip = 'Text labels only (lines/alerts stay active)')
preMarket30Color = input.color(color.purple, '30-min level color', group = '🌅 Pre-Market Levels')
preMarket10Color = input.color(color.yellow, '10-min level color', group = '🌅 Pre-Market Levels')

// === SPEZIAL-EVENTS (FOMC/NFP) - RULE OF 4 + PRESS CONFERENCE ===
enableSpecialEvent = input.bool(false, 'Event mode active', group = '📰 FOMC/NFP Events')
eventHour = input.int(20, 'News release hour (CET)', minval = 0, maxval = 23, group = '📰 FOMC/NFP Events', tooltip = 'FOMC: 20:00 CET (14:00 Eastern)')
eventMinute = input.int(0, 'News Release Minute', minval = 0, maxval = 59, group = '📰 FOMC/NFP Events', tooltip = 'Usually :00 (full hour)')
showRuleOf4 = input.bool(true, 'Rule of 4 Bar (10-Min)', group = '📰 FOMC/NFP Events', tooltip = 'The 4th 10-min candle after the news release (30 min later)')
showPressConf5Min = input.bool(true, 'Press Conference Bar (5-Min)', group = '📰 FOMC/NFP Events', tooltip = 'The 5-min candle 30 min after the news release')
eventColor = input.color(color.fuchsia, 'Event level color', group = '📰 FOMC/NFP Events')
ruleOf4Color = input.color(color.yellow, 'Rule of 4 color', group = '📰 FOMC/NFP Events')
eventColorLong = input.color(color.green, 'Long signal color', group = '📰 FOMC/NFP Events')
eventColorShort = input.color(color.red, 'Short signal color', group = '📰 FOMC/NFP Events')

// === VOLUMEN-ANALYSE ===
showVolEU1st  = input.bool(true, 'EU 1st candle volume',      group = '📉 Volume analysis')
showVolUS1st  = input.bool(true, 'US 1st candle volume',      group = '📉 Volume analysis')
showVolEU4th  = input.bool(true, 'EU 4th candle breakouts',  group = '📉 Volume analysis')
showVolUS4th  = input.bool(true, 'US 4th candle breakouts',  group = '📉 Volume analysis')
showVol15Min  = input.bool(true, '15-min breakouts',        group = '📉 Volume analysis')
volThreshold  = input.float(1.5, 'Volume threshold (x average)', minval = 1.0, maxval = 3.0, step = 0.1, group = '📉 Volume analysis')
volPeriod     = input.int(20, 'Averaging period', minval = 5, maxval = 100, group = '📉 Volume analysis')

// === BREAKOUT CONFIRMATION ===
breakoutMode        = input.string('Volume-confirmed', 'Breakout mode', options = ['Immediate', 'Volume-confirmed'], group = '⚡ Breakout confirmation')
breakoutVolThreshold = input.float(1.0, 'Min. volume for a breakout (x average)', minval = 0.5, maxval = 2.0, step = 0.1, group = '⚡ Breakout confirmation', tooltip = 'A breakout only counts if volume is above this value')

// === RETEST-EINSTELLUNGEN ===
showRetestLabels = input.bool(true, 'Show retest labels', group = '↩️ Retest settings')
showRetestAlerts = input.bool(true, 'Enable retest alerts', group = '↩️ Retest settings')
retestLabelColorEU = input.color(color.blue, 'EU retest color', group = '↩️ Retest settings')
retestLabelColorUS = input.color(color.orange, 'US retest color', group = '↩️ Retest settings')

// === ZEITZONE & ZEITUMSTELLUNG ===
// EU times (9h, 10h, 8h etc.) need no shift — Europe/Berlin adjusts automatically.
// US times (15h, 16h, 17h, 14h in Berlin time) must be shifted during the DST gap.
dstMode = input.string('Auto', 'DST mode', options = ['Auto', 'Manual'], group = '🕐 Timezone & DST', tooltip = 'Auto = detects the US/EU DST shift automatically from the Berlin-NY time difference')
manualEUDST = input.bool(true, 'EU summer time (CET→CEST)', group = '🕐 Timezone & DST', tooltip = 'Manual mode only: is the EU currently on summer time?')
manualUSDST = input.bool(true, 'US summer time (EST→EDT)', group = '🕐 Timezone & DST', tooltip = 'Manual mode only: is the US currently on summer time?')

tz = 'Europe/Berlin'

// auto-detection: Berlin-NY difference -> shift for US times
// 6h = both equal (both winter or both summer) -> no shift
// 5h = US already summer, EU still winter -> US times 1h earlier
// 7h = EU already summer, US still winter -> US times 1h later
f_autoUSDSTShift() =>
    berlinH = hour(time, "Europe/Berlin")
    nyH     = hour(time, "America/New_York")
    diff    = (berlinH - nyH + 24) % 24
    diff == 5 ? -1 : diff == 7 ? 1 : 0

f_manualUSDSTShift() =>
    if manualUSDST and not manualEUDST
        -1   // US summer, EU winter -> US times 1h earlier
    else if not manualUSDST and manualEUDST
        1    // EU summer, US winter -> US times 1h later
    else
        0    // both equal -> no shift

usDSTShift = dstMode == 'Auto' ? f_autoUSDSTShift() : f_manualUSDSTShift()
getUSHour(h) => (h + usDSTShift + 24) % 24

// EU DST shift: 0 in CET (winter, UTC+1), 1 in CEST (summer, UTC+2)
// Asian markets (HK50, JPN225) have no DST -> appear 1h later in Berlin time
euDSTShift = (hour(time, "Europe/Berlin") - hour(time, "UTC") + 24) % 24 == 2 ? 1 : 0
getAsianHour(h) => (h + euDSTShift + 24) % 24

// symbol detection
isHK50Symbol = str.contains(syminfo.ticker, "HK") or str.contains(syminfo.ticker, "HSI") or str.contains(syminfo.ticker, "HK50")
isJPN225Symbol = str.contains(syminfo.ticker, "JPN") or str.contains(syminfo.ticker, "JP225") or str.contains(syminfo.ticker, "NKY") or str.contains(syminfo.ticker, "NIK")
tickerLower = str.lower(syminfo.ticker)
isGoldSymbol = str.contains(tickerLower, "xau") or str.contains(tickerLower, "gold") or str.contains(tickerLower, "gc")
isSilverSymbol = str.contains(tickerLower, "xag") or str.contains(tickerLower, "silver")
isCopperSymbol = str.contains(tickerLower, "copper") or str.contains(tickerLower, "hg") or str.contains(tickerLower, "xcu")
isCommoditySymbol = isGoldSymbol or isSilverSymbol or isCopperSymbol
isForexSymbol = (str.contains(tickerLower, "eur") or str.contains(tickerLower, "gbp") or str.contains(tickerLower, "jpy") or str.contains(tickerLower, "aud") or str.contains(tickerLower, "nzd") or str.contains(tickerLower, "cad") or str.contains(tickerLower, "chf")) and not isCommoditySymbol

currentAvgVol = ta.sma(volume, volPeriod)
getVolLabel(vol, avgVol) =>
    relVol   = vol / avgVol * 100
    volText  = str.tostring(math.round(relVol)) + '% Vol'
    volColor = vol > avgVol * volThreshold ? color.green : vol > avgVol ? color.orange : color.red
    volSymbol = vol > avgVol * volThreshold ? '✓ ' : vol > avgVol ? '⚠ ' : '✗ '
    [volText, volColor, volSymbol, relVol]
isBreakoutConfirmed(vol, avgVol) =>
    breakoutMode == 'Immediate' or vol >= avgVol * breakoutVolThreshold

// === 15-MINUTEN CANDLES ===
[time15, high15, low15, open15, close15, vol15] = request.security(syminfo.tickerid, '15', [time, high, low, open, close, volume])
avgVol15 = ta.sma(vol15, volPeriod)

isEU15_2nd = hour(time15, tz) == 9  and minute(time15, tz) == 15
isUS15_2nd = hour(time15, tz) == getUSHour(15) and minute(time15, tz) == 45
isHK15_230 = hour(time15, tz) == getAsianHour(2)  and minute(time15, tz) == 30
isEU15_7th = hour(time15, tz) == 10 and minute(time15, tz) == 30
isUS15_7th = hour(time15, tz) == getUSHour(17) and minute(time15, tz) == 0

isEU15_2nd_closed = hour(time15, tz) == 9  and minute(time15, tz) == 30
isUS15_2nd_closed = hour(time15, tz) == getUSHour(16) and minute(time15, tz) == 0
isHK15_230_closed = hour(time15, tz) == getAsianHour(2)  and minute(time15, tz) == 45
isEU15_7th_closed = hour(time15, tz) == 10 and minute(time15, tz) == 45
isUS15_7th_closed = hour(time15, tz) == getUSHour(17) and minute(time15, tz) == 15

// --- EU 15m 2. Candle ---
var float euH15 = na, var float euL15 = na
var line euHighLine = na, var line euLowLine = na, var box euBox = na
var bool euHighBroken = false, var bool euLowBroken = false
var bool euHighClosedOutside = false, var bool euLowClosedOutside = false
var bool euHighRetested = false, var bool euLowRetested = false, var bool euLevelsReady = false

// --- EU 15m 7. Candle ---
var float euH15_7 = na, var float euL15_7 = na
var line euHighLine_7 = na, var line euLowLine_7 = na, var box euBox_7 = na
var bool euHighBroken_7 = false, var bool euLowBroken_7 = false
var bool euHighClosedOutside_7 = false, var bool euLowClosedOutside_7 = false
var bool euHighRetested_7 = false, var bool euLowRetested_7 = false, var bool euLevelsReady_7 = false

// --- US 15m 2. Candle ---
var float usH15 = na, var float usL15 = na
var line usHighLine = na, var line usLowLine = na, var box usBox = na
var bool usHighBroken = false, var bool usLowBroken = false
var bool usHighClosedOutside = false, var bool usLowClosedOutside = false
var bool usHighRetested = false, var bool usLowRetested = false, var bool usLevelsReady = false

// --- US 15m 7. Candle ---
var float usH15_7 = na, var float usL15_7 = na
var line usHighLine_7 = na, var line usLowLine_7 = na, var box usBox_7 = na
var bool usHighBroken_7 = false, var bool usLowBroken_7 = false
var bool usHighClosedOutside_7 = false, var bool usLowClosedOutside_7 = false
var bool usHighRetested_7 = false, var bool usLowRetested_7 = false, var bool usLevelsReady_7 = false

// --- HK50 15m 02:30 ---
var float hkH15 = na, var float hkL15 = na
var line hkHighLine = na, var line hkLowLine = na, var box hkBox = na
var bool hkHighBroken = false, var bool hkLowBroken = false, var bool hkLevelsReady = false

// --- Gold 01:45 ---
var float goldH15_0145 = na, var float goldL15_0145 = na
var line goldHighLine_0145 = na, var line goldLowLine_0145 = na, var box goldBox_0145 = na
var bool goldHighBroken_0145 = false, var bool goldLowBroken_0145 = false
var bool goldHighClosedOutside_0145 = false, var bool goldLowClosedOutside_0145 = false
var bool goldHighRetested_0145 = false, var bool goldLowRetested_0145 = false, var bool goldLevelsReady_0145 = false

// --- Gold 14:15 ---
var float goldH15_1415 = na, var float goldL15_1415 = na
var line goldHighLine_1415 = na, var line goldLowLine_1415 = na, var box goldBox_1415 = na
var bool goldHighBroken_1415 = false, var bool goldLowBroken_1415 = false
var bool goldHighClosedOutside_1415 = false, var bool goldLowClosedOutside_1415 = false
var bool goldHighRetested_1415 = false, var bool goldLowRetested_1415 = false, var bool goldLevelsReady_1415 = false

// --- Forex 08:15 ---
var float fxH15_0815 = na, var float fxL15_0815 = na
var line fxHighLine_0815 = na, var line fxLowLine_0815 = na, var box fxBox_0815 = na
var bool fxHighBroken_0815 = false, var bool fxLowBroken_0815 = false
var bool fxHighClosedOutside_0815 = false, var bool fxLowClosedOutside_0815 = false
var bool fxHighRetested_0815 = false, var bool fxLowRetested_0815 = false, var bool fxLevelsReady_0815 = false

// === ALERT TRIGGER VARIABLEN ===
var bool triggerEU2ndHigh = false, var bool triggerEU2ndLow = false
var bool triggerEU2ndHighRetest = false, var bool triggerEU2ndLowRetest = false
var bool triggerEU7thHigh = false, var bool triggerEU7thLow = false
var bool triggerEU7thHighRetest = false, var bool triggerEU7thLowRetest = false
var bool triggerUS2ndHigh = false, var bool triggerUS2ndLow = false
var bool triggerUS2ndHighRetest = false, var bool triggerUS2ndLowRetest = false
var bool triggerUS7thHigh = false, var bool triggerUS7thLow = false
var bool triggerUS7thHighRetest = false, var bool triggerUS7thLowRetest = false
var bool triggerHK50High = false, var bool triggerHK50Low = false
var bool triggerJPN225High = false, var bool triggerJPN225Low = false
var bool triggerEU1stLow = false, var bool triggerEU4thHigh = false, var bool triggerEU4thLow = false
var bool triggerUS1stLow = false, var bool triggerUS4thHigh = false, var bool triggerUS4thLow = false
var bool triggerEU30PreLow = false, var bool triggerUS30PreLow = false
var bool triggerEU10PreHigh = false, var bool triggerEU10PreLow = false
var bool triggerUS10PreHigh = false, var bool triggerUS10PreLow = false
var bool triggerRuleOf4Long = false, var bool triggerRuleOf4Short = false
var bool triggerPressConfLong = false, var bool triggerPressConfShort = false
var bool triggerGold0145High = false, var bool triggerGold0145Low = false
var bool triggerGold0145HighRetest = false, var bool triggerGold0145LowRetest = false
var bool triggerGold1415High = false, var bool triggerGold1415Low = false
var bool triggerGold1415HighRetest = false, var bool triggerGold1415LowRetest = false
var bool triggerFX0815High = false, var bool triggerFX0815Low = false
var bool triggerFX0815HighRetest = false, var bool triggerFX0815LowRetest = false
var bool trigger8BallEUHigh = false, var bool trigger8BallEULow = false
var bool triggerTeenEUHigh  = false, var bool triggerTeenEULow  = false
var bool trigger8BallUSHigh = false, var bool trigger8BallUSLow = false
var bool triggerTeenUSHigh  = false, var bool triggerTeenUSLow  = false

// Reset triggers each bar
triggerEU2ndHigh := false, triggerEU2ndLow := false, triggerEU2ndHighRetest := false, triggerEU2ndLowRetest := false
triggerEU7thHigh := false, triggerEU7thLow := false, triggerEU7thHighRetest := false, triggerEU7thLowRetest := false
triggerUS2ndHigh := false, triggerUS2ndLow := false, triggerUS2ndHighRetest := false, triggerUS2ndLowRetest := false
triggerUS7thHigh := false, triggerUS7thLow := false, triggerUS7thHighRetest := false, triggerUS7thLowRetest := false
triggerHK50High := false, triggerHK50Low := false, triggerJPN225High := false, triggerJPN225Low := false
triggerEU1stLow := false, triggerEU4thHigh := false, triggerEU4thLow := false
triggerUS1stLow := false, triggerUS4thHigh := false, triggerUS4thLow := false
triggerEU30PreLow := false, triggerUS30PreLow := false
triggerEU10PreHigh := false, triggerEU10PreLow := false, triggerUS10PreHigh := false, triggerUS10PreLow := false
triggerRuleOf4Long := false, triggerRuleOf4Short := false
triggerPressConfLong := false, triggerPressConfShort := false
triggerGold0145High := false, triggerGold0145Low := false, triggerGold0145HighRetest := false, triggerGold0145LowRetest := false
triggerGold1415High := false, triggerGold1415Low := false, triggerGold1415HighRetest := false, triggerGold1415LowRetest := false
triggerFX0815High := false, triggerFX0815Low := false, triggerFX0815HighRetest := false, triggerFX0815LowRetest := false
trigger8BallEUHigh := false, trigger8BallEULow := false, triggerTeenEUHigh := false, triggerTeenEULow := false
trigger8BallUSHigh := false, trigger8BallUSLow := false, triggerTeenUSHigh := false, triggerTeenUSLow := false

// ===== EU 15-Min: 2. Candle =====
if isEU15_2nd and showEU and showEU_2nd15
    euLevelsReady := false
    line.delete(euHighLine), line.delete(euLowLine), box.delete(euBox)
    euBox := box.new(bar_index, high15, bar_index + 1, low15, border_color = euColor, bgcolor = color.new(euColor, 90), border_width = lineWidth, text = 'EU 2nd (15min)', text_color = euColor, text_size = size.small)
    euHighLine := line.new(bar_index, high15, bar_index + 1, high15, color = euColor, width = lineWidth, extend = extend.right)
    euLowLine  := line.new(bar_index, low15, bar_index + 1, low15, color = euColor, width = lineWidth, extend = extend.right)

if isEU15_2nd_closed and showEU and showEU_2nd15
    euH15 := high15[1], euL15 := low15[1]
    euHighBroken := false, euLowBroken := false, euHighClosedOutside := false, euLowClosedOutside := false
    euHighRetested := false, euLowRetested := false, euLevelsReady := true

if showEU and showEU_2nd15 and euLevelsReady and not na(euH15) and showVol15Min
    if not na(euHighLine) and high > line.get_y1(euHighLine) and not euHighBroken and isBreakoutConfirmed(volume, currentAvgVol)
        euHighBroken := true, triggerEU2ndHigh := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, high, volSymbol + volText + ' (EU 2nd)', color = volColor, textcolor = color.white, style = label.style_label_down, size = size.small)
    if euHighBroken and not euHighClosedOutside and not na(euHighLine) and low > line.get_y1(euHighLine)
        euHighClosedOutside := true
    if euHighBroken and euHighClosedOutside and not euHighRetested and not na(euHighLine) and low <= line.get_y1(euHighLine)
        euHighRetested := true
        if showRetestAlerts
            triggerEU2ndHighRetest := true
        if showRetestLabels
            lbl(bar_index, low, 'Retest (EU 2nd H)', color = retestLabelColorEU, textcolor = color.white, style = label.style_label_up, size = size.small)
    if not na(euLowLine) and low < line.get_y1(euLowLine) and not euLowBroken and isBreakoutConfirmed(volume, currentAvgVol)
        euLowBroken := true, triggerEU2ndLow := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, low, volSymbol + volText + ' (EU 2nd)', color = volColor, textcolor = color.white, style = label.style_label_up, size = size.small)
    if euLowBroken and not euLowClosedOutside and not na(euLowLine) and high < line.get_y1(euLowLine)
        euLowClosedOutside := true
    if euLowBroken and euLowClosedOutside and not euLowRetested and not na(euLowLine) and high >= line.get_y1(euLowLine)
        euLowRetested := true
        if showRetestAlerts
            triggerEU2ndLowRetest := true
        if showRetestLabels
            lbl(bar_index, high, 'Retest (EU 2nd L)', color = retestLabelColorEU, textcolor = color.white, style = label.style_label_down, size = size.small)

// ===== EU 15-Min: 7. Candle =====
if isEU15_7th and showEU and showEU_7th15
    euLevelsReady_7 := false
    line.delete(euHighLine_7), line.delete(euLowLine_7), box.delete(euBox_7)
    euBox_7 := box.new(bar_index, high15, bar_index + 1, low15, border_color = euColor, bgcolor = color.new(euColor, 90), border_width = lineWidth, text = 'EU 7th (15min)', text_color = euColor, text_size = size.small)
    euHighLine_7 := line.new(bar_index, high15, bar_index + 1, high15, color = euColor, width = lineWidth, extend = extend.right)
    euLowLine_7  := line.new(bar_index, low15, bar_index + 1, low15, color = euColor, width = lineWidth, extend = extend.right)

