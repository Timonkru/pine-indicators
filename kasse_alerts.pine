        jpnHighBroken := true, triggerJPN225High := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, high, volSymbol + volText + ' (JPN225 00:50)', color = volColor, textcolor = color.white, style = label.style_label_down, size = size.small)
    if not na(jpnLowLine) and low < line.get_y1(jpnLowLine) and not jpnLowBroken and isBreakoutConfirmed(volume, currentAvgVol)
        jpnLowBroken := true, triggerJPN225Low := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, low, volSymbol + volText + ' (JPN225 00:50)', color = volColor, textcolor = color.white, style = label.style_label_up, size = size.small)
plotshape(isJPN10_050 and showJPN and showJPN_050 and timeframe.period == '10' and isJPN225Symbol, 'JPN225 00:50', shape.diamond, location.belowbar, jpnColor, size = size.small)

// === PRE-MARKET LEVELS ===
[time30, high30, low30, vol30] = request.security(syminfo.tickerid, '30', [time, high, low, volume])
isEU30PreMarket = hour(time30, tz) == 8 and minute(time30, tz) == 30
isUS30PreMarket = hour(time30, tz) == getUSHour(15) and minute(time30, tz) == 0
isEU10PreMarket = hour(time10, tz) == 8 and minute(time10, tz) == 50
isUS10PreMarket = hour(time10, tz) == getUSHour(15) and minute(time10, tz) == 20
var line eu30PreLine = na, var line us30PreLine = na
var line eu10PreHighLine = na, var line eu10PreLowLine = na
var line us10PreHighLine = na, var line us10PreLowLine = na
var float eu30PreLow = na, var float us30PreLow = na
var float eu10PreHigh = na, var float eu10PreLow = na
var float us10PreHigh = na, var float us10PreLow = na
var bool eu30PreBroken = false, var bool us30PreBroken = false
var bool eu10PreHighBroken = false, var bool eu10PreLowBroken = false
var bool us10PreHighBroken = false, var bool us10PreLowBroken = false

if isEU30PreMarket and showEU and showPreMarket30
    eu30PreLow := low30, eu30PreBroken := false
    line.delete(eu30PreLine)
    eu30PreLine := line.new(bar_index, low30, bar_index + 1, low30, color = preMarket30Color, width = lineWidth, style = line.style_dotted, extend = extend.right)
    if showPreMarketLabels
        lbl(bar_index, low30, 'EU 30m Pre-Low', color = preMarket30Color, textcolor = color.white, style = label.style_label_up, size = size.tiny)
if showEU and showPreMarket30 and not na(eu30PreLow) and not eu30PreBroken and not isEU30PreMarket
    if low < eu30PreLow and isBreakoutConfirmed(volume, currentAvgVol)
        eu30PreBroken := true, triggerEU30PreLow := true
if isUS30PreMarket and showUS and showPreMarket30
    us30PreLow := low30, us30PreBroken := false
    line.delete(us30PreLine)
    us30PreLine := line.new(bar_index, low30, bar_index + 1, low30, color = preMarket30Color, width = lineWidth, style = line.style_dotted, extend = extend.right)
    if showPreMarketLabels
        lbl(bar_index, low30, 'US 30m Pre-Low', color = preMarket30Color, textcolor = color.white, style = label.style_label_up, size = size.tiny)
if showUS and showPreMarket30 and not na(us30PreLow) and not us30PreBroken and not isUS30PreMarket
    if low < us30PreLow and isBreakoutConfirmed(volume, currentAvgVol)
        us30PreBroken := true, triggerUS30PreLow := true
if isEU10PreMarket and showEU and showPreMarket10
    eu10PreHigh := high10, eu10PreLow := low10, eu10PreHighBroken := false, eu10PreLowBroken := false
    line.delete(eu10PreHighLine), line.delete(eu10PreLowLine)
    eu10PreHighLine := line.new(bar_index, high10, bar_index + 1, high10, color = preMarket10Color, width = lineWidth, style = line.style_dotted, extend = extend.right)
    eu10PreLowLine := line.new(bar_index, low10, bar_index + 1, low10, color = preMarket10Color, width = lineWidth, style = line.style_dotted, extend = extend.right)
    if showPreMarketLabels
        lbl(bar_index, high10, 'EU 10m Pre-H', color = preMarket10Color, textcolor = color.white, style = label.style_label_down, size = size.tiny)
        lbl(bar_index, low10, 'EU 10m Pre-L', color = preMarket10Color, textcolor = color.white, style = label.style_label_up, size = size.tiny)
if showEU and showPreMarket10 and not na(eu10PreHigh) and not isEU10PreMarket
    if high > eu10PreHigh and not eu10PreHighBroken and isBreakoutConfirmed(volume, currentAvgVol)
        eu10PreHighBroken := true, triggerEU10PreHigh := true
    if low < eu10PreLow and not eu10PreLowBroken and isBreakoutConfirmed(volume, currentAvgVol)
        eu10PreLowBroken := true, triggerEU10PreLow := true
if isUS10PreMarket and showUS and showPreMarket10
    us10PreHigh := high10, us10PreLow := low10, us10PreHighBroken := false, us10PreLowBroken := false
    line.delete(us10PreHighLine), line.delete(us10PreLowLine)
    us10PreHighLine := line.new(bar_index, high10, bar_index + 1, high10, color = preMarket10Color, width = lineWidth, style = line.style_dotted, extend = extend.right)
    us10PreLowLine := line.new(bar_index, low10, bar_index + 1, low10, color = preMarket10Color, width = lineWidth, style = line.style_dotted, extend = extend.right)
    if showPreMarketLabels
        lbl(bar_index, high10, 'US 10m Pre-H', color = preMarket10Color, textcolor = color.white, style = label.style_label_down, size = size.tiny)
        lbl(bar_index, low10, 'US 10m Pre-L', color = preMarket10Color, textcolor = color.white, style = label.style_label_up, size = size.tiny)
if showUS and showPreMarket10 and not na(us10PreHigh) and not isUS10PreMarket
    if high > us10PreHigh and not us10PreHighBroken and isBreakoutConfirmed(volume, currentAvgVol)
        us10PreHighBroken := true, triggerUS10PreHigh := true
    if low < us10PreLow and not us10PreLowBroken and isBreakoutConfirmed(volume, currentAvgVol)
        us10PreLowBroken := true, triggerUS10PreLow := true

// === 5-MINUTEN CANDLES ===
[time5, high5, low5, open5, close5, vol5] = request.security(syminfo.tickerid, '5', [time, high, low, open, close, volume])
avgVol5 = ta.sma(vol5, volPeriod)
isEU5First  = hour(time5, tz) == 9  and minute(time5, tz) == 0
isEU5Fourth = hour(time5, tz) == 9  and minute(time5, tz) == 15
isUS5First  = hour(time5, tz) == getUSHour(15) and minute(time5, tz) == 30
isUS5Fourth = hour(time5, tz) == getUSHour(15) and minute(time5, tz) == 45
isEU5First_closed  = hour(time5, tz) == 9  and minute(time5, tz) == 5
isEU5Fourth_closed = hour(time5, tz) == 9  and minute(time5, tz) == 20
isUS5First_closed  = hour(time5, tz) == getUSHour(15) and minute(time5, tz) == 35
isUS5Fourth_closed = hour(time5, tz) == getUSHour(15) and minute(time5, tz) == 50

var line eu5FirstLine = na, var line eu5FourthHighLine = na, var line eu5FourthLowLine = na
var float eu5FirstLow = na, var bool eu5FirstBullish = false, var bool eu5FirstLowBroken = false
var float eu5FourthHigh = na, var float eu5FourthLow = na
var bool eu5FourthHighBroken = false, var bool eu5FourthLowBroken = false
var bool eu5FirstReady = false, var bool eu5FourthReady = false

var line us5FirstLine = na, var line us5FourthHighLine = na, var line us5FourthLowLine = na
var float us5FirstLow = na, var bool us5FirstBullish = false, var bool us5FirstLowBroken = false
var float us5FourthHigh = na, var float us5FourthLow = na
var bool us5FourthHighBroken = false, var bool us5FourthLowBroken = false
var bool us5FirstReady = false, var bool us5FourthReady = false

if isEU5First and show5MinEU and showEU
    eu5FirstReady := false
    if showEU1stLow
        line.delete(eu5FirstLine)
        eu5FirstLine := line.new(bar_index, low5, bar_index + 1, low5, color = eu5MinColor, width = lineWidth, style = line.style_dashed, extend = extend.right)
if isEU5First_closed and show5MinEU and showEU
    eu5FirstLow := low5[1], eu5FirstBullish := close5[1] > open5[1], eu5FirstLowBroken := false, eu5FirstReady := true
    if not eu5FirstBullish and showVolEU1st
        [volText, volColor, volSymbol, relVol] = getVolLabel(vol5[1], avgVol5)
        lbl(bar_index, eu5FirstLow, volSymbol + volText + ' (1st bearish)', color = volColor, textcolor = color.white, style = label.style_label_up, size = size.small)
if show5MinEU and showEU and eu5FirstReady and not na(eu5FirstLow) and not eu5FirstLowBroken and showVolEU1st and not eu5FirstBullish
    if low < eu5FirstLow and isBreakoutConfirmed(volume, currentAvgVol)
        eu5FirstLowBroken := true, triggerEU1stLow := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, low, volSymbol + volText + ' (1st break)', color = volColor, textcolor = color.white, style = label.style_label_up, size = size.small)
if isEU5Fourth and show5MinEU and showEU
    eu5FourthReady := false
    line.delete(eu5FourthHighLine), line.delete(eu5FourthLowLine)
    eu5FourthHighLine := line.new(bar_index, high5, bar_index + 1, high5, color = eu5MinColor, width = lineWidth, extend = extend.right)
    eu5FourthLowLine  := line.new(bar_index, low5, bar_index + 1, low5, color = eu5MinColor, width = lineWidth, extend = extend.right)
if isEU5Fourth_closed and show5MinEU and showEU
    eu5FourthHigh := high5[1], eu5FourthLow := low5[1], eu5FourthHighBroken := false, eu5FourthLowBroken := false, eu5FourthReady := true
if show5MinEU and showEU and eu5FourthReady and not na(eu5FourthHigh) and showVolEU4th
    if high > eu5FourthHigh and not eu5FourthHighBroken and isBreakoutConfirmed(volume, currentAvgVol)
        eu5FourthHighBroken := true, triggerEU4thHigh := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, high, volSymbol + volText + ' (4th)', color = volColor, textcolor = color.white, style = label.style_label_down, size = size.small)
    if low < eu5FourthLow and not eu5FourthLowBroken and isBreakoutConfirmed(volume, currentAvgVol)
        eu5FourthLowBroken := true, triggerEU4thLow := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, low, volSymbol + volText + ' (4th)', color = volColor, textcolor = color.white, style = label.style_label_up, size = size.small)

if isUS5First and show5MinUS and showUS
    us5FirstReady := false
    if showUS1stLow
        line.delete(us5FirstLine)
        us5FirstLine := line.new(bar_index, low5, bar_index + 1, low5, color = us5MinColor, width = lineWidth, style = line.style_dashed, extend = extend.right)
if isUS5First_closed and show5MinUS and showUS
    us5FirstLow := low5[1], us5FirstBullish := close5[1] > open5[1], us5FirstLowBroken := false, us5FirstReady := true
    if not us5FirstBullish and showVolUS1st
        [volText, volColor, volSymbol, relVol] = getVolLabel(vol5[1], avgVol5)
        lbl(bar_index, us5FirstLow, volSymbol + volText + ' (1st bearish)', color = volColor, textcolor = color.white, style = label.style_label_up, size = size.small)
if show5MinUS and showUS and us5FirstReady and not na(us5FirstLow) and not us5FirstLowBroken and showVolUS1st and not us5FirstBullish
    if low < us5FirstLow and isBreakoutConfirmed(volume, currentAvgVol)
        us5FirstLowBroken := true, triggerUS1stLow := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, low, volSymbol + volText + ' (1st break)', color = volColor, textcolor = color.white, style = label.style_label_up, size = size.small)
if isUS5Fourth and show5MinUS and showUS
    us5FourthReady := false
    line.delete(us5FourthHighLine), line.delete(us5FourthLowLine)
    us5FourthHighLine := line.new(bar_index, high5, bar_index + 1, high5, color = us5MinColor, width = lineWidth, extend = extend.right)
    us5FourthLowLine  := line.new(bar_index, low5, bar_index + 1, low5, color = us5MinColor, width = lineWidth, extend = extend.right)
if isUS5Fourth_closed and show5MinUS and showUS
    us5FourthHigh := high5[1], us5FourthLow := low5[1], us5FourthHighBroken := false, us5FourthLowBroken := false, us5FourthReady := true
if show5MinUS and showUS and us5FourthReady and not na(us5FourthHigh) and showVolUS4th
    if high > us5FourthHigh and not us5FourthHighBroken and isBreakoutConfirmed(volume, currentAvgVol)
        us5FourthHighBroken := true, triggerUS4thHigh := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, high, volSymbol + volText + ' (4th)', color = volColor, textcolor = color.white, style = label.style_label_down, size = size.small)
    if low < us5FourthLow and not us5FourthLowBroken and isBreakoutConfirmed(volume, currentAvgVol)
        us5FourthLowBroken := true, triggerUS4thLow := true
        [volText, volColor, volSymbol, relVol] = getVolLabel(volume, currentAvgVol)
        lbl(bar_index, low, volSymbol + volText + ' (4th)', color = volColor, textcolor = color.white, style = label.style_label_up, size = size.small)

// === 8 BALL & TEENAGER STRATEGIE (Tom Hougaard) ===
// 8 Ball = 8th 5-min bar after the open, Teenager = 13th bar
// orderly filter: bar only counts if range <= orderlyMult * avg range of the preceding bars
range5_avg7_pre  = request.security(syminfo.tickerid, '5', ta.sma(high - low, 7)[2])
range5_avg12_pre = request.security(syminfo.tickerid, '5', ta.sma(high - low, 12)[2])

isEU5_8th         = hour(time5, tz) == 9  and minute(time5, tz) == 35
isEU5_8th_closed  = hour(time5, tz) == 9  and minute(time5, tz) == 40
isEU5_13th        = hour(time5, tz) == 10 and minute(time5, tz) == 0
isEU5_13th_closed = hour(time5, tz) == 10 and minute(time5, tz) == 5
isUS5_8th         = hour(time5, tz) == getUSHour(16) and minute(time5, tz) == 5
isUS5_8th_closed  = hour(time5, tz) == getUSHour(16) and minute(time5, tz) == 10
isUS5_13th        = hour(time5, tz) == getUSHour(16) and minute(time5, tz) == 30
isUS5_13th_closed = hour(time5, tz) == getUSHour(16) and minute(time5, tz) == 35

var line ball_eu_H = na, var line ball_eu_L = na, var box ball_eu_Box = na
var float ball_eu_H_lvl = na, var float ball_eu_L_lvl = na
var bool ball_eu_H_brk = false, var bool ball_eu_L_brk = false, var bool ball_eu_ready = false, var bool ball_eu_orderly = false

var line teen_eu_H = na, var line teen_eu_L = na, var box teen_eu_Box = na
var float teen_eu_H_lvl = na, var float teen_eu_L_lvl = na
var bool teen_eu_H_brk = false, var bool teen_eu_L_brk = false, var bool teen_eu_ready = false, var bool teen_eu_orderly = false

var line ball_us_H = na, var line ball_us_L = na, var box ball_us_Box = na
var float ball_us_H_lvl = na, var float ball_us_L_lvl = na
var bool ball_us_H_brk = false, var bool ball_us_L_brk = false, var bool ball_us_ready = false, var bool ball_us_orderly = false

var line teen_us_H = na, var line teen_us_L = na, var box teen_us_Box = na
var float teen_us_H_lvl = na, var float teen_us_L_lvl = na
var bool teen_us_H_brk = false, var bool teen_us_L_brk = false, var bool teen_us_ready = false, var bool teen_us_orderly = false

orderlyOK(barRange, avgPre) =>
    na(avgPre) or avgPre == 0 ? true : barRange <= avgPre * orderlyMult

// --- EU 8 Ball ---
if isEU5_8th and show8Ball and show8BallEU and showEU
    ball_eu_ready := false
    line.delete(ball_eu_H), line.delete(ball_eu_L), box.delete(ball_eu_Box)
    ball_eu_Box := box.new(bar_index, high5, bar_index + 1, low5, border_color = ballColor, bgcolor = color.new(ballColor, 88), border_width = lineWidth, text = 'EU 8 Ball', text_color = ballColor, text_size = size.small)
    ball_eu_H := line.new(bar_index, high5, bar_index + 1, high5, color = ballColor, width = lineWidth, extend = extend.right)
    ball_eu_L := line.new(bar_index, low5,  bar_index + 1, low5,  color = ballColor, width = lineWidth, extend = extend.right)
if isEU5_8th_closed and show8Ball and show8BallEU and showEU
    barRange = high5[1] - low5[1]
    ball_eu_orderly := orderlyOK(barRange, range5_avg7_pre)
    ball_eu_H_lvl := high5[1], ball_eu_L_lvl := low5[1]
    ball_eu_H_brk := false, ball_eu_L_brk := false, ball_eu_ready := true
    if not ball_eu_orderly
        lbl(bar_index, high5[1], '⚠ EU 8 Ball OUTLIER (skipped)', color = color.gray, textcolor = color.white, style = label.style_label_down, size = size.small)
if show8Ball and show8BallEU and showEU and ball_eu_ready and ball_eu_orderly and not na(ball_eu_H_lvl)
    if high > ball_eu_H_lvl and not ball_eu_H_brk and isBreakoutConfirmed(volume, currentAvgVol)
        ball_eu_H_brk := true, trigger8BallEUHigh := true
        lbl(bar_index, high, '▲ EU 8 Ball H', color = ballColor, textcolor = color.white, style = label.style_label_down, size = size.small)
    if low < ball_eu_L_lvl and not ball_eu_L_brk and isBreakoutConfirmed(volume, currentAvgVol)
        ball_eu_L_brk := true, trigger8BallEULow := true
        lbl(bar_index, low,  '▼ EU 8 Ball L', color = ballColor, textcolor = color.white, style = label.style_label_up, size = size.small)

// --- EU Teenager ---
if isEU5_13th and show8Ball and showTeenEU and showEU
    teen_eu_ready := false
    line.delete(teen_eu_H), line.delete(teen_eu_L), box.delete(teen_eu_Box)
    teen_eu_Box := box.new(bar_index, high5, bar_index + 1, low5, border_color = teenColor, bgcolor = color.new(teenColor, 88), border_width = lineWidth, text = 'EU Teenager', text_color = teenColor, text_size = size.small)
    teen_eu_H := line.new(bar_index, high5, bar_index + 1, high5, color = teenColor, width = lineWidth, extend = extend.right)
    teen_eu_L := line.new(bar_index, low5,  bar_index + 1, low5,  color = teenColor, width = lineWidth, extend = extend.right)
if isEU5_13th_closed and show8Ball and showTeenEU and showEU
    barRange = high5[1] - low5[1]
    teen_eu_orderly := orderlyOK(barRange, range5_avg12_pre)
    teen_eu_H_lvl := high5[1], teen_eu_L_lvl := low5[1]
    teen_eu_H_brk := false, teen_eu_L_brk := false, teen_eu_ready := true
    if not teen_eu_orderly
        lbl(bar_index, high5[1], '⚠ EU Teenager OUTLIER (skipped)', color = color.gray, textcolor = color.white, style = label.style_label_down, size = size.small)
if show8Ball and showTeenEU and showEU and teen_eu_ready and teen_eu_orderly and not na(teen_eu_H_lvl)
    if high > teen_eu_H_lvl and not teen_eu_H_brk and isBreakoutConfirmed(volume, currentAvgVol)
        teen_eu_H_brk := true, triggerTeenEUHigh := true
        lbl(bar_index, high, '▲ EU Teenager H', color = teenColor, textcolor = color.white, style = label.style_label_down, size = size.small)
    if low < teen_eu_L_lvl and not teen_eu_L_brk and isBreakoutConfirmed(volume, currentAvgVol)
        teen_eu_L_brk := true, triggerTeenEULow := true
        lbl(bar_index, low,  '▼ EU Teenager L', color = teenColor, textcolor = color.white, style = label.style_label_up, size = size.small)

// --- US 8 Ball ---
if isUS5_8th and show8Ball and show8BallUS and showUS
    ball_us_ready := false
    line.delete(ball_us_H), line.delete(ball_us_L), box.delete(ball_us_Box)
    ball_us_Box := box.new(bar_index, high5, bar_index + 1, low5, border_color = ballColor, bgcolor = color.new(ballColor, 88), border_width = lineWidth, text = 'US 8 Ball', text_color = ballColor, text_size = size.small)
    ball_us_H := line.new(bar_index, high5, bar_index + 1, high5, color = ballColor, width = lineWidth, extend = extend.right)
    ball_us_L := line.new(bar_index, low5,  bar_index + 1, low5,  color = ballColor, width = lineWidth, extend = extend.right)
if isUS5_8th_closed and show8Ball and show8BallUS and showUS
    barRange = high5[1] - low5[1]
    ball_us_orderly := orderlyOK(barRange, range5_avg7_pre)
    ball_us_H_lvl := high5[1], ball_us_L_lvl := low5[1]
    ball_us_H_brk := false, ball_us_L_brk := false, ball_us_ready := true
    if not ball_us_orderly
        lbl(bar_index, high5[1], '⚠ US 8 Ball OUTLIER (skipped)', color = color.gray, textcolor = color.white, style = label.style_label_down, size = size.small)
if show8Ball and show8BallUS and showUS and ball_us_ready and ball_us_orderly and not na(ball_us_H_lvl)
    if high > ball_us_H_lvl and not ball_us_H_brk and isBreakoutConfirmed(volume, currentAvgVol)
        ball_us_H_brk := true, trigger8BallUSHigh := true
        lbl(bar_index, high, '▲ US 8 Ball H', color = ballColor, textcolor = color.white, style = label.style_label_down, size = size.small)
    if low < ball_us_L_lvl and not ball_us_L_brk and isBreakoutConfirmed(volume, currentAvgVol)
        ball_us_L_brk := true, trigger8BallUSLow := true
        lbl(bar_index, low,  '▼ US 8 Ball L', color = ballColor, textcolor = color.white, style = label.style_label_up, size = size.small)

// --- US Teenager ---
if isUS5_13th and show8Ball and showTeenUS and showUS
    teen_us_ready := false
    line.delete(teen_us_H), line.delete(teen_us_L), box.delete(teen_us_Box)
    teen_us_Box := box.new(bar_index, high5, bar_index + 1, low5, border_color = teenColor, bgcolor = color.new(teenColor, 88), border_width = lineWidth, text = 'US Teenager', text_color = teenColor, text_size = size.small)
    teen_us_H := line.new(bar_index, high5, bar_index + 1, high5, color = teenColor, width = lineWidth, extend = extend.right)
    teen_us_L := line.new(bar_index, low5,  bar_index + 1, low5,  color = teenColor, width = lineWidth, extend = extend.right)
if isUS5_13th_closed and show8Ball and showTeenUS and showUS
    barRange = high5[1] - low5[1]
    teen_us_orderly := orderlyOK(barRange, range5_avg12_pre)
    teen_us_H_lvl := high5[1], teen_us_L_lvl := low5[1]
    teen_us_H_brk := false, teen_us_L_brk := false, teen_us_ready := true
    if not teen_us_orderly
        lbl(bar_index, high5[1], '⚠ US Teenager OUTLIER (skipped)', color = color.gray, textcolor = color.white, style = label.style_label_down, size = size.small)
if show8Ball and showTeenUS and showUS and teen_us_ready and teen_us_orderly and not na(teen_us_H_lvl)
    if high > teen_us_H_lvl and not teen_us_H_brk and isBreakoutConfirmed(volume, currentAvgVol)
        teen_us_H_brk := true, triggerTeenUSHigh := true
        lbl(bar_index, high, '▲ US Teenager H', color = teenColor, textcolor = color.white, style = label.style_label_down, size = size.small)
    if low < teen_us_L_lvl and not teen_us_L_brk and isBreakoutConfirmed(volume, currentAvgVol)
        teen_us_L_brk := true, triggerTeenUSLow := true
        lbl(bar_index, low,  '▼ US Teenager L', color = teenColor, textcolor = color.white, style = label.style_label_up, size = size.small)

// === RULE OF 4: 4. 10-MIN KERZE NACH NEWS RELEASE ===
// News Release: eventHour:eventMinute (z.B. 20:00)
// 4th candle = +30 min (e.g. 20:30-20:40)
// detection uses chart time (multi-TF compatible)
ruleOf4Min = (eventMinute + 30) % 60
ruleOf4Hour = eventMinute + 30 >= 60 ? (eventHour + 1) % 24 : eventHour

isRuleOf4 = enableSpecialEvent and hour(time, tz) == ruleOf4Hour and minute(time, tz) >= ruleOf4Min and minute(time, tz) < ruleOf4Min + 10

var line ruleOf4HighLine = na, var line ruleOf4LowLine = na, var box ruleOf4Box = na
var float ruleOf4High = na, var float ruleOf4Low = na
var float ruleOf4BuildHigh = na, var float ruleOf4BuildLow = na
var bool ruleOf4LongTriggered = false, var bool ruleOf4ShortTriggered = false
var bool ruleOf4Ready = false, var bool ruleOf4Building = false

if isRuleOf4 and showRuleOf4
    if not ruleOf4Building
        ruleOf4Building := true
        ruleOf4Ready := false
        ruleOf4BuildHigh := high
        ruleOf4BuildLow := low
        line.delete(ruleOf4HighLine), line.delete(ruleOf4LowLine), box.delete(ruleOf4Box)
        ruleOf4Box := box.new(time, high, time + 10 * 60 * 1000, low, border_color = ruleOf4Color, bgcolor = color.new(ruleOf4Color, 85), border_width = lineWidth, text = 'Rule of 4 (10m)', text_color = ruleOf4Color, text_size = size.small, xloc = xloc.bar_time)
        ruleOf4HighLine := line.new(time, high, time + 10 * 60 * 1000, high, color = ruleOf4Color, width = lineWidth, extend = extend.right, xloc = xloc.bar_time)
        ruleOf4LowLine := line.new(time, low, time + 10 * 60 * 1000, low, color = ruleOf4Color, width = lineWidth, extend = extend.right, xloc = xloc.bar_time)
    else
        if high > ruleOf4BuildHigh
            ruleOf4BuildHigh := high
        if low < ruleOf4BuildLow
            ruleOf4BuildLow := low
        box.set_top(ruleOf4Box, ruleOf4BuildHigh), box.set_bottom(ruleOf4Box, ruleOf4BuildLow)
        line.set_y1(ruleOf4HighLine, ruleOf4BuildHigh), line.set_y2(ruleOf4HighLine, ruleOf4BuildHigh)
        line.set_y1(ruleOf4LowLine, ruleOf4BuildLow), line.set_y2(ruleOf4LowLine, ruleOf4BuildLow)
if not isRuleOf4 and ruleOf4Building
    ruleOf4Building := false
    ruleOf4High := ruleOf4BuildHigh, ruleOf4Low := ruleOf4BuildLow
    ruleOf4LongTriggered := false, ruleOf4ShortTriggered := false, ruleOf4Ready := true
if enableSpecialEvent and showRuleOf4 and ruleOf4Ready and not na(ruleOf4High)
    if close > ruleOf4High and not ruleOf4LongTriggered
        ruleOf4LongTriggered := true, triggerRuleOf4Long := true
        lbl(bar_index, high, '▲ LONG (Rule of 4)', color = eventColorLong, textcolor = color.white, style = label.style_label_down, size = size.normal)
    if close < ruleOf4Low and not ruleOf4ShortTriggered
        ruleOf4ShortTriggered := true, triggerRuleOf4Short := true
        lbl(bar_index, low, '▼ SHORT (Rule of 4)', color = eventColorShort, textcolor = color.white, style = label.style_label_up, size = size.normal)

// === FOMC PRESS CONFERENCE LOGIC ===
// press conference starts 30 minutes after the news release
// detection uses chart time (multi-TF compatible)
pressConfMin = (eventMinute + 30) % 60
pressConfHour = eventMinute + 30 >= 60 ? (eventHour + 1) % 24 : eventHour

isPressConf = enableSpecialEvent and hour(time, tz) == pressConfHour and minute(time, tz) >= pressConfMin and minute(time, tz) < pressConfMin + 5

var line pressConfHighLine = na, var line pressConfLowLine = na, var box pressConfBox = na
var float pressConfHigh = na, var float pressConfLow = na
var float pressConfBuildHigh = na, var float pressConfBuildLow = na
var bool pressConfLongTriggered = false, var bool pressConfShortTriggered = false
var bool pressConfReady = false, var bool pressConfBuilding = false

if isPressConf and showPressConf5Min
    if not pressConfBuilding
        pressConfBuilding := true
        pressConfReady := false
        pressConfBuildHigh := high
        pressConfBuildLow := low
        line.delete(pressConfHighLine), line.delete(pressConfLowLine), box.delete(pressConfBox)
        pressConfBox := box.new(time, high, time + 5 * 60 * 1000, low, border_color = eventColor, bgcolor = color.new(eventColor, 85), border_width = lineWidth, text = 'Press Conf (5m)', text_color = eventColor, text_size = size.small, xloc = xloc.bar_time)
        pressConfHighLine := line.new(time, high, time + 5 * 60 * 1000, high, color = eventColor, width = lineWidth, extend = extend.right, xloc = xloc.bar_time)
        pressConfLowLine := line.new(time, low, time + 5 * 60 * 1000, low, color = eventColor, width = lineWidth, extend = extend.right, xloc = xloc.bar_time)
    else
        if high > pressConfBuildHigh
            pressConfBuildHigh := high
        if low < pressConfBuildLow
            pressConfBuildLow := low
        box.set_top(pressConfBox, pressConfBuildHigh), box.set_bottom(pressConfBox, pressConfBuildLow)
        line.set_y1(pressConfHighLine, pressConfBuildHigh), line.set_y2(pressConfHighLine, pressConfBuildHigh)
        line.set_y1(pressConfLowLine, pressConfBuildLow), line.set_y2(pressConfLowLine, pressConfBuildLow)
if not isPressConf and pressConfBuilding
    pressConfBuilding := false
    pressConfHigh := pressConfBuildHigh, pressConfLow := pressConfBuildLow
    pressConfLongTriggered := false, pressConfShortTriggered := false, pressConfReady := true
if enableSpecialEvent and showPressConf5Min and pressConfReady and not na(pressConfHigh)
    if close > pressConfHigh and not pressConfLongTriggered
        pressConfLongTriggered := true, triggerPressConfLong := true
        lbl(bar_index, high, '▲ LONG (Press Conf)', color = eventColorLong, textcolor = color.white, style = label.style_label_down, size = size.normal)
    if close < pressConfLow and not pressConfShortTriggered
        pressConfShortTriggered := true, triggerPressConfShort := true
        lbl(bar_index, low, '▼ SHORT (Press Conf)', color = eventColorShort, textcolor = color.white, style = label.style_label_up, size = size.normal)

// === ALERT CONDITIONS ===
anyBreakout = triggerEU2ndHigh or triggerEU2ndLow or triggerEU7thHigh or triggerEU7thLow or triggerUS2ndHigh or triggerUS2ndLow or triggerUS7thHigh or triggerUS7thLow or triggerHK50High or triggerHK50Low or triggerJPN225High or triggerJPN225Low or triggerEU1stLow or triggerEU4thHigh or triggerEU4thLow or triggerUS1stLow or triggerUS4thHigh or triggerUS4thLow or triggerEU30PreLow or triggerUS30PreLow or triggerEU10PreHigh or triggerEU10PreLow or triggerUS10PreHigh or triggerUS10PreLow or triggerRuleOf4Long or triggerRuleOf4Short or triggerPressConfLong or triggerPressConfShort or triggerGold0145High or triggerGold0145Low or triggerGold1415High or triggerGold1415Low or triggerFX0815High or triggerFX0815Low or trigger8BallEUHigh or trigger8BallEULow or triggerTeenEUHigh or triggerTeenEULow or trigger8BallUSHigh or trigger8BallUSLow or triggerTeenUSHigh or triggerTeenUSLow
anyRetest = triggerEU2ndHighRetest or triggerEU2ndLowRetest or triggerEU7thHighRetest or triggerEU7thLowRetest or triggerUS2ndHighRetest or triggerUS2ndLowRetest or triggerUS7thHighRetest or triggerUS7thLowRetest or triggerGold0145HighRetest or triggerGold0145LowRetest or triggerGold1415HighRetest or triggerGold1415LowRetest or triggerFX0815HighRetest or triggerFX0815LowRetest
anyEUBreakout = triggerEU2ndHigh or triggerEU2ndLow or triggerEU7thHigh or triggerEU7thLow or triggerEU1stLow or triggerEU4thHigh or triggerEU4thLow or triggerEU30PreLow or triggerEU10PreHigh or triggerEU10PreLow
anyUSBreakout = triggerUS2ndHigh or triggerUS2ndLow or triggerUS7thHigh or triggerUS7thLow or triggerUS1stLow or triggerUS4thHigh or triggerUS4thLow or triggerUS30PreLow or triggerUS10PreHigh or triggerUS10PreLow
anyGoldBreakout = triggerGold0145High or triggerGold0145Low or triggerGold1415High or triggerGold1415Low
anyForexBreakout = triggerFX0815High or triggerFX0815Low
any8BallBreakout = trigger8BallEUHigh or trigger8BallEULow or trigger8BallUSHigh or trigger8BallUSLow
anyTeenBreakout  = triggerTeenEUHigh or triggerTeenEULow or triggerTeenUSHigh or triggerTeenUSLow

// === ECHTZEIT-ALERTS ===
if triggerEU2ndHigh
    alert(syminfo.ticker + ' - EU 2nd 15min HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU2ndLow
    alert(syminfo.ticker + ' - EU 2nd 15min LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU7thHigh
    alert(syminfo.ticker + ' - EU 7th 15min HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU7thLow
    alert(syminfo.ticker + ' - EU 7th 15min LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS2ndHigh
    alert(syminfo.ticker + ' - US 2nd 15min HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS2ndLow
    alert(syminfo.ticker + ' - US 2nd 15min LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS7thHigh
    alert(syminfo.ticker + ' - US 7th 15min HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS7thLow
    alert(syminfo.ticker + ' - US 7th 15min LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU1stLow
    alert(syminfo.ticker + ' - EU 1st 5min LOW (bearish) broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU4thHigh
    alert(syminfo.ticker + ' - EU 4th 5min HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU4thLow
    alert(syminfo.ticker + ' - EU 4th 5min LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS1stLow
    alert(syminfo.ticker + ' - US 1st 5min LOW (bearish) broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS4thHigh
    alert(syminfo.ticker + ' - US 4th 5min HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS4thLow
    alert(syminfo.ticker + ' - US 4th 5min LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerHK50High or triggerHK50Low
    alert(syminfo.ticker + ' - HK50 Level broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerJPN225High or triggerJPN225Low
    alert(syminfo.ticker + ' - JPN225 Level broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU30PreLow
    alert(syminfo.ticker + ' - EU 30min Pre-Market LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS30PreLow
    alert(syminfo.ticker + ' - US 30min Pre-Market LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU10PreHigh
    alert(syminfo.ticker + ' - EU 10min Pre-Market HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerEU10PreLow
    alert(syminfo.ticker + ' - EU 10min Pre-Market LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS10PreHigh
    alert(syminfo.ticker + ' - US 10min Pre-Market HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerUS10PreLow
    alert(syminfo.ticker + ' - US 10min Pre-Market LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerRuleOf4Long
    alert(syminfo.ticker + ' - ▲ Rule of 4 LONG - close above 4th 10m bar high @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerRuleOf4Short
    alert(syminfo.ticker + ' - ▼ Rule of 4 SHORT - close below 4th 10m bar low @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerPressConfLong
    alert(syminfo.ticker + ' - ▲ FOMC LONG - close above press conference high @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerPressConfShort
    alert(syminfo.ticker + ' - ▼ FOMC SHORT - close below press conference low @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerGold0145High
    alert(syminfo.ticker + ' - Gold 01:45 HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerGold0145Low
    alert(syminfo.ticker + ' - Gold 01:45 LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerGold1415High
    alert(syminfo.ticker + ' - Gold 14:15 HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerGold1415Low
    alert(syminfo.ticker + ' - Gold 14:15 LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerFX0815High
    alert(syminfo.ticker + ' - FX 08:15 HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerFX0815Low
    alert(syminfo.ticker + ' - FX 08:15 LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if trigger8BallEUHigh
    alert(syminfo.ticker + ' - ▲ EU 8 Ball HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if trigger8BallEULow
    alert(syminfo.ticker + ' - ▼ EU 8 Ball LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerTeenEUHigh
    alert(syminfo.ticker + ' - ▲ EU Teenager HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerTeenEULow
    alert(syminfo.ticker + ' - ▼ EU Teenager LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if trigger8BallUSHigh
    alert(syminfo.ticker + ' - ▲ US 8 Ball HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if trigger8BallUSLow
    alert(syminfo.ticker + ' - ▼ US 8 Ball LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerTeenUSHigh
    alert(syminfo.ticker + ' - ▲ US Teenager HIGH broken @ ' + str.tostring(close), alert.freq_once_per_bar)
if triggerTeenUSLow
    alert(syminfo.ticker + ' - ▼ US Teenager LOW broken @ ' + str.tostring(close), alert.freq_once_per_bar)
// Retest Alerts
if showRetestAlerts and triggerEU2ndHighRetest
    alert(syminfo.ticker + ' - EU 2nd HIGH Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerEU2ndLowRetest
    alert(syminfo.ticker + ' - EU 2nd LOW Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerEU7thHighRetest
    alert(syminfo.ticker + ' - EU 7th HIGH Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerEU7thLowRetest
    alert(syminfo.ticker + ' - EU 7th LOW Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerUS2ndHighRetest
    alert(syminfo.ticker + ' - US 2nd HIGH Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerUS2ndLowRetest
    alert(syminfo.ticker + ' - US 2nd LOW Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerUS7thHighRetest
    alert(syminfo.ticker + ' - US 7th HIGH Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerUS7thLowRetest
    alert(syminfo.ticker + ' - US 7th LOW Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerGold0145HighRetest
    alert(syminfo.ticker + ' - Gold 01:45 HIGH Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerGold0145LowRetest
    alert(syminfo.ticker + ' - Gold 01:45 LOW Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerGold1415HighRetest
    alert(syminfo.ticker + ' - Gold 14:15 HIGH Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerGold1415LowRetest
    alert(syminfo.ticker + ' - Gold 14:15 LOW Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerFX0815HighRetest
    alert(syminfo.ticker + ' - FX 08:15 HIGH Retest @ ' + str.tostring(close), alert.freq_once_per_bar)
if showRetestAlerts and triggerFX0815LowRetest
    alert(syminfo.ticker + ' - FX 08:15 LOW Retest @ ' + str.tostring(close), alert.freq_once_per_bar)

// === ALERTCONDITIONS ===
alertcondition(anyBreakout, title='All breaks', message='{{ticker}} - Level broken @ {{close}}')
alertcondition(anyRetest, title='All retests', message='{{ticker}} - Retest @ {{close}}')
alertcondition(anyBreakout or anyRetest, title='Breaks + Retests', message='{{ticker}} - Break/Retest @ {{close}}')
alertcondition(anyEUBreakout, title='EU breaks', message='{{ticker}} - EU Level @ {{close}}')
alertcondition(anyUSBreakout, title='US breaks', message='{{ticker}} - US Level @ {{close}}')
alertcondition(triggerEU2ndHigh, title='EU 2nd HIGH', message='{{ticker}} - EU 2nd 15m HIGH @ {{close}}')
alertcondition(triggerEU2ndLow, title='EU 2nd LOW', message='{{ticker}} - EU 2nd 15m LOW @ {{close}}')
