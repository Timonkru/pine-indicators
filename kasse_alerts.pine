alertcondition(triggerEU10PreLow, title='EU 10m Pre LOW', message='{{ticker}} - EU 10m Pre LOW @ {{close}}')
alertcondition(triggerUS10PreHigh, title='US 10m Pre HIGH', message='{{ticker}} - US 10m Pre HIGH @ {{close}}')
alertcondition(triggerUS10PreLow, title='US 10m Pre LOW', message='{{ticker}} - US 10m Pre LOW @ {{close}}')
alertcondition(triggerRuleOf4Long or triggerRuleOf4Short, title='Rule of 4 Signal', message='{{ticker}} - Rule of 4 Signal @ {{close}}')
alertcondition(triggerPressConfLong or triggerPressConfShort, title='FOMC Signal', message='{{ticker}} - FOMC Signal @ {{close}}')
alertcondition(triggerRuleOf4Long or triggerRuleOf4Short or triggerPressConfLong or triggerPressConfShort, title='All event signals', message='{{ticker}} - Event Signal @ {{close}}')
